local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/bawfwabva-commits/ui/refs/heads/main/lib"))()
getgenv().Library = Library

local Window = Library:CreateWindow({
    Prefix = "Akatsuki.", 
    Suffix = "havoc", 
    Size = UDim2.new(0, 500, 0, 700), 
    Position = UDim2.fromScale(0.5, 0.2), 
    AnchorPoint = Vector2.new(0.5, 0.3)
})

local Combat = Window:AddTab({Title = "Combat", Columns = 1})
local Visuals = Window:AddTab({Title = "Visuals", Columns = 1})
local Movement = Window:AddTab({Title = "Movement", Columns = 1})
local Misc = Window:AddTab({Title = "Misc", Columns = 1})
local Utility = Window:AddTab({Title = "Utility", Columns = 1})

Window:InitPanels()
Library:AutoLoad()

Library:Notify({Text = "Havoc Hub successfully loaded!", Lifetime = 5})
