local uiLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/0x3u-debug/Roblox/refs/heads/main/uiLib"))()

local Window = uiLib:CreateWindow({Prefix = "Verya", Suffix = ".gg", Size = UDim2.new(0, 559, 0, 668), Position = UDim2.fromScale(0.5, 0), AnchorPoint = Vector2.new(0.5, 0)})

local Combat = Window:AddTab({Title = "Combat", Columns = 2})
