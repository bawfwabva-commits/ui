local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/bawfwabva-commits/ui/refs/heads/main/lib"))()
getgenv().Library = Library

local Window = Library:CreateWindow({
    Prefix = "gamesense.", 
    Suffix = "pub", 
    Size = UDim2.new(0, 500, 0, 700), 
    Position = UDim2.fromScale(0.5, 0.2), 
    AnchorPoint = Vector2.new(0.5, 0.3)
})

local Combat = Window:AddTab({Title = "Combat", Columns = 2})
local Visuals = Window:AddTab({Title = "Visuals", Columns = 2})
local Movement = Window:AddTab({Title = "Movement", Columns = 2})
local Misc = Window:AddTab({Title = "Misc", Columns = 2})
local Utility = Window:AddTab({Title = "Utility", Columns = 2})

local AimbotSettings = Combat:AddSection({Title = "Aimbot Settings", Side = 1})
local SilentAimSettings = Combat:AddSection({Title = "Silent Aim Settings", Side = 1})
local TargetAimSettings = Combat:AddSection({Title = "Target Settings", Side = 2})
local WeaponsAimSettings = Combat:AddSection({Title = "Weapons Settings", Side = 2})

local AimbotGroup
local SilentGroup

AimbotSettings:AddToggle({Text = "Enabled", Flag = "Aimbot", Default = false, Callback = function(Bool)
    if AimbotGroup then
        AimbotGroup:SetVisible(Bool)
    end
end})

SilentAimSettings:AddToggle({Text = "Enabled", Flag = "Aimbot", Default = false, Callback = function(Bool)
    if SilentGroup then
        SilentGroup:SetVisible(Bool)
    end
end})

AimbotGroup = AimbotSettings:AddGroup({Indent = 10, Visible = false})
SilentGroup = SilentAimSettings:AddGroup({Indent = 10, Visible = false})

AimbotGroup:AddKeyPicker({Text = "Toggle Key", Flag = "AimbotToggleKey", Key = Enum.UserInputType.MouseButton2, Mode = "Hold", Active = false, ShowInList = true, Callback = print})
AimbotGroup:AddToggle({Text = "Visible Only", Flag = "AimbotVisibleOnly", Default = false, Callback = print})
AimbotGroup:AddToggle({Text = "Sticky Lock", Flag = "AimbotStickyLock", Default = false, Callback = print})
AimbotGroup:AddSlider({Text = "FOV", Flag = "AimbotFOV", Min = 0, Max = 360, Rounding = 1, Default = 90, Suffix = "deg", Type = "Normal", Callback = print})
AimbotGroup:AddSlider({Text = "Smoothing", Flag = "AimbotSmoothing", Min = 0, Max = 100, Rounding = 1, Default = 50, Suffix = "%", Callback = print})
AimbotGroup:AddSlider({Text = "Max Distance", Flag = "SilentMaxDistance", Min = 0, Max = 3000, Rounding = 1, Default = 1000, Suffix = "studs", Callback = print})

SilentGroup:AddToggle({Text = "Visible Only", Flag = "SilentVisibleOnly", Default = false, Callback = print})
SilentGroup:AddToggle({Text = "Sticky Lock", Flag = "SilentStickyLock", Default = false, Callback = print})
SilentGroup:AddSlider({Text = "FOV", Flag = "SilentFOV", Min = 0, Max = 360, Rounding = 1, Default = 90, Suffix = "deg", Type = "Normal", Callback = print})
SilentGroup:AddSlider({Text = "Max Distance", Flag = "SilentMaxDistance", Min = 0, Max = 3000, Rounding = 1, Default = 1000, Suffix = "studs", Callback = print})
SilentGroup:AddDropdown({Text = "Hitbox", Flag = "SilentHitbox", Values = {"Head", "Torso", "Sync Target Settings"}, Default = "Sync Target Settings", Callback = print})

TargetAimSettings:AddToggle({Text = "NPCS", Flag = "TargetVisibleOnly", Default = false, Callback = print}):Tooltip({Name = '<font color = "rgb(255, 0, 0)">Aimbot/Silent Aim</font> will also works at AI Scavs/Raiders.'})
TargetAimSettings:AddDropdown({Text = "Hitbox", Flag = "TargetHitbox", Values = {"Head", "Torso", "Closest"}, Default = "Head", Callback = print})
TargetAimSettings:AddDropdown({Text = "Priority", Flag = "TargetPriority", Values = {"Distance", "Damage"}, Default = "Distance", Callback = print})
TargetAimSettings:AddToggle({Text = "Visible Only", Flag = "TargetVisibleOnly", Default = false, Callback = print})
TargetAimSettings:AddToggle({Text = "Ease Out", Flag = "TargetEaseOut", Default = false, Callback = print})
TargetAimSettings:AddToggle({Text = "Bullet Prediction", Flag = "TargetBulletPrediction", Default = false, Callback = print}):Tooltip({Name = "Trying to predict projectile's trajectory."})

WeaponsAimSettings:AddToggle({Text = "Fast Equip", Flag = "WeaponFastEquip", Default = false, Callback = print})
WeaponsAimSettings:AddToggle({Text = "Instant ADS", Flag = "WeaponInstantADS", Default = false, Callback = print}):Tooltip({Name = "Removes aiming down sights delay."})
WeaponsAimSettings:AddDropdown({
    Text = "Mods", 
    Flag = "WeaponMods", 
    Values = {
        "No Spread", 
        "No Weapon Recoil", 
        "No Camera Recoil", 
        "No Weapon Sway",
        "No Land Bob",
        "No Walk Bob",
        "No Suppression Blur"
    }, 
    Default = {}, 
    Multi = true, 
    Callback = function(selected)
        print("Updated weapon/camera modifications")
    end
})

Window:InitPanels()

task.wait(Library.TweeningSpeed)

for Name, Value in Library.Themes.Preset do
    Library:Refresh(Name, Value)
end

Library:AutoLoad()

Library:Notify({Text = "Havoc Hub successfully loaded!", Lifetime = 5})
